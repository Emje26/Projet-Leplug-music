<div class="assistant-page">

  <header class="assistant-header">
    <%= link_to profile_path, class: "hdr-back" do %>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="16" height="16">
        <path d="M15 6l-6 6 6 6"/>
      </svg>
    <% end %>
    <div class="hdr-title">
      <span class="hdr-kicker">"ASSISTANT"</span>
      <h1>PLUG/AI</h1>
    </div>
    <div class="hdr-spacer"></div>
  </header>

  <!-- Action bar -->
  <div class="assistant-actions">
    <% if @can_save_recipe %>
      <%= button_to "SAVE DROP →",
                    assistant_save_path,
                    method: :post,
                    class: "btn-signal",
                    form: { style: "display:inline-block;margin:0;" } %>
    <% else %>
      <span class="assistant-hint">"ASK THE AI FOR A RECIPE TO ENABLE SAVING"</span>
    <% end %>

    <%= button_to "RESET CHAT",
                  reset_chat_path,
                  method: :post,
                  class: "btn-ghost",
                  form: { style: "display:inline-block;margin:0;" } %>
  </div>

  <!-- Flash -->
  <% if notice %><div class="alert alert-primary"><%= notice %></div><% end %>
  <% if alert  %><div class="alert alert-danger"><%=  alert  %></div><% end %>

  <!-- Chat window -->
  <div class="chat-window">
    <% if @messages.blank? %>
      <div class="chat-bubble assistant">
        <span class="bubble-label">AI / C/O LE PLUG</span>
        Salut. Décris-moi ce que tu veux créer — style, ambiance, référence, contraintes.
        Je te renvoie une suggestion de structure et d'ingrédients sonores.
      </div>
    <% else %>
      <% @messages.each do |message| %>
        <% if message["role"] == "user" %>
          <div class="chat-bubble user">
            <span class="bubble-label">YOU</span>
            <%= simple_format(message["content"]) %>
          </div>
        <% else %>
          <div class="chat-bubble assistant">
            <span class="bubble-label">AI / C/O LE PLUG</span>
            <%= simple_format(message["content"]) %>
          </div>
        <% end %>
      <% end %>
    <% end %>
  </div>

  <!-- Input -->
  <%= form_with url: assistant_talk_path, method: :post, data: { turbo: false }, class: "assistant-form" do %>
    <%= text_area_tag :message, nil,
          rows: 2,
          placeholder: "EX: BEAT TRAP 90 BPM, PIANO MINEUR, INSPIRATION NINHO…",
          class: "assistant-input" %>
    <button type="submit" class="btn-signal">SEND →</button>
  <% end %>

</div>

<nav class="bottom-nav">
  <%= link_to root_path, class: "nav-item" do %>
    <svg viewBox="0 0 24 24"><path d="M3 10.5L12 3l9 7.5V21H3V10.5z"/></svg>
    <span>FEED</span>
  <% end %>
  <a class="nav-item" href="#">
    <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.5" y2="16.5"/></svg>
    <span>SEARCH</span>
  </a>
  <div class="nav-item nav-drop"><button class="drop-btn">+</button></div>
  <%= link_to chats_path, class: "nav-item" do %>
    <svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
    <span>DMS</span>
  <% end %>
  <%= link_to profile_path, class: "nav-item" do %>
    <svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"/><path d="M4 21a8 8 0 0 1 16 0"/></svg>
    <span>ME</span>
  <% end %>
</nav>
