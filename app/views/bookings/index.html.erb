<div class="search-page results">
  <header class="results-header">
    <%= link_to search_path, class: "back-btn" do %>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="16" height="16"><path d="M15 6l-6 6 6 6"/></svg>
    <% end %>
    <div class="results-title-wrap">
      <span class="results-kicker">"MES BOOKINGS"</span>
      <h1 class="results-title"><%= @bookings.size %> RÉSA<%= "S" if @bookings.size != 1 %></h1>
    </div>
    <span class="header-spacer"></span>
  </header>

  <% if @bookings.any? %>
    <div class="results-list">
      <% @bookings.each do |b| %>
        <%= link_to booking_path(b), class: "result-row" do %>
          <div class="rr-cover"><span><%= b.bookable&.initials || "??" %></span></div>
          <div class="rr-body">
            <h3 class="rr-name"><%= b.bookable&.name.to_s.upcase %></h3>
            <div class="rr-sub"><%= b.bookable_label %> · <%= b.date %> · <%= b.duration_hours %>H · <%= b.status.upcase %></div>
          </div>
          <span class="rr-price">€<%= format("%.2f", b.total || 0) %></span>
          <span class="rr-arrow">›</span>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state" style="margin: 40px 20px;">
      <span class="empty-ix">0</span>
      <h3 class="empty-title">AUCUN BOOKING</h3>
      <p class="empty-text">TA PREMIÈRE RÉSA COMMENCE PAR LE SEARCH</p>
      <%= link_to "SEARCH →", search_path, class: "btn-signal" %>
    </div>
  <% end %>
</div>

<%= render "shared/bottom_nav", active: :search %>
