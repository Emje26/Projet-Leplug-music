<% bookable_path = @bookable.is_a?(Studio) ? studio_path(@bookable) : talent_path(@bookable) %>

<div class="booking-page">

  <header class="booking-header">
    <%= link_to bookings_path, class: "back-btn" do %>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="16" height="16"><path d="M15 6l-6 6 6 6"/></svg>
    <% end %>
    <div class="booking-title-wrap">
      <span class="booking-kicker">"CONFIRMÉ" — № <%= @booking.id.to_s.rjust(4, "0") %></span>
      <h1 class="booking-title">BOOKING<br>RÉCAP.</h1>
    </div>
    <span class="header-spacer"></span>
  </header>

  <section class="booking-bookable">
    <div class="bb-cover"><span><%= @bookable.initials %></span></div>
    <div class="bb-body">
      <span class="bb-type"><%= @booking.bookable_label.gsub(/^/, '"') + '"' %></span>
      <h2 class="bb-name">
        <%= link_to @bookable.name.upcase, bookable_path, style: "color:inherit;text-decoration:none;" %>
      </h2>
      <span class="bb-price">€<%= @booking.hourly_price.to_i %>/H · <%= @booking.duration_hours %>H</span>
    </div>
  </section>

  <section class="booking-section">
    <span class="bsec-label">"DÉTAILS"</span>
    <div class="details-grid">
      <div>
        <span class="dg-k">DATE</span>
        <span class="dg-v"><%= I18n.l(@booking.date, format: "%d %b %Y") rescue @booking.date.to_s %></span>
      </div>
      <div>
        <span class="dg-k">CRÉNEAU</span>
        <span class="dg-v"><%= @booking.start_time&.strftime("%H:%M") || "—" %></span>
      </div>
      <div>
        <span class="dg-k">DURÉE</span>
        <span class="dg-v"><%= @booking.duration_hours %>H</span>
      </div>
      <div>
        <span class="dg-k">STATUT</span>
        <span class="dg-v" style="color: var(--signal);"><%= @booking.status.upcase %></span>
      </div>
    </div>
  </section>

  <section class="booking-section">
    <span class="bsec-label">"RÉCAPITULATIF"</span>
    <div class="summary-card">
      <div class="sum-row">
        <span class="sum-k">Sous-total</span>
        <span class="sum-v mono">€<%= format("%.2f", @booking.subtotal) %></span>
      </div>
      <div class="sum-row">
        <span class="sum-k">Frais de service <span class="sum-hint">(15%)</span></span>
        <span class="sum-v mono">€<%= format("%.2f", @booking.service_fee) %></span>
      </div>
      <div class="sum-divider"></div>
      <div class="sum-row total">
        <span class="sum-k">Total</span>
        <span class="sum-v mono">€<%= format("%.2f", @booking.total) %></span>
      </div>
    </div>
  </section>

  <div class="booking-cta">
    <%= link_to "← RETOUR AU SEARCH", search_path, class: "btn-ghost", style: "width: 100%; height: 54px;" %>
  </div>

</div>

<%= render "shared/bottom_nav", active: :search %>
