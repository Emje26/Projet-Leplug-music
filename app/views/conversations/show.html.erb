<div class="convo-page">

  <!-- HEADER -->
  <header class="convo-header">
    <%= link_to chats_path, class: "convo-back" do %>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><path d="M15 6l-6 6 6 6"/></svg>
    <% end %>
    <div class="convo-avatar"><%= @partner[:initials] %></div>
    <div class="convo-info">
      <div class="convo-name"><%= @partner[:name] %></div>
      <div class="convo-status"><%= @partner[:role] %></div>
    </div>
    <% if @partner[:online] %><div class="convo-online"></div><% end %>
    <button class="convo-dots" aria-label="Menu">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><circle cx="12" cy="5" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="12" cy="19" r="1.5"/></svg>
    </button>
  </header>

  <!-- MESSAGES -->
  <div class="convo-messages">
    <% @messages.each do |m| %>

      <% if m[:type] == :date %>
        <div class="msg-date"><span><%= m[:text] %></span></div>

      <% elsif m[:type] == :system %>
        <div class="msg-system"><span><%= m[:text] %></span></div>

      <% elsif m[:from] == :me %>
        <div class="msg-row msg-sent">
          <div class="msg-bubble msg-bubble-sent">
            <% if m[:audio] %>
              <div class="audio-msg">
                <div class="audio-play-btn"><svg width="10" height="12" viewBox="0 0 10 12" fill="var(--ink)"><path d="M0 0L10 6L0 12z"/></svg></div>
                <div class="audio-wave">
                  <% m[:audio][:bars].each_with_index do |h, i| %>
                    <div class="wave-bar <%= i < m[:audio][:played] ? 'played-sent' : 'unplayed-sent' %>" style="height:<%= h %>px"></div>
                  <% end %>
                </div>
                <div class="audio-duration-sent"><%= m[:audio][:duration] %></div>
              </div>
            <% end %>
            <% if m[:text] %><div class="msg-text"><%= m[:text] %></div><% end %>
            <div class="msg-time"><%= m[:time] %></div>
          </div>
        </div>

      <% else %>
        <div class="msg-row msg-received">
          <div class="msg-avatar"><%= @partner[:initials] %></div>
          <div>
            <div class="msg-bubble msg-bubble-recv">
              <% if m[:text] %><div class="msg-text"><%= m[:text] %></div><% end %>

              <% if m[:audio] %>
                <div class="audio-msg">
                  <div class="audio-play-btn"><svg width="10" height="12" viewBox="0 0 10 12" fill="var(--accent)"><path d="M0 0L10 6L0 12z"/></svg></div>
                  <div class="audio-wave">
                    <% m[:audio][:bars].each_with_index do |h, i| %>
                      <div class="wave-bar <%= i < m[:audio][:played] ? 'played' : 'unplayed' %>" style="height:<%= h %>px"></div>
                    <% end %>
                  </div>
                  <div class="audio-duration"><%= m[:audio][:duration] %></div>
                </div>
              <% end %>

              <% if m[:track] %>
                <div class="track-preview">
                  <div class="tp-cover"><svg viewBox="0 0 10 12" fill="var(--accent)" width="14" height="16"><path d="M0 0L10 6L0 12z"/></svg></div>
                  <div class="tp-info">
                    <div class="tp-title"><%= m[:track][:title] %></div>
                    <div class="tp-meta"><%= m[:track][:duration] %></div>
                    <div class="tp-meta"><%= m[:track][:bpm] %> · <%= m[:track][:genre] %></div>
                  </div>
                </div>
              <% end %>

              <% if m[:card] %>
                <div class="msg-card">
                  <span class="q msg-card-label"><%= m[:card][:label] %></span>
                  <div class="msg-card-title"><%= m[:card][:title] %></div>
                  <div class="msg-card-sub"><%= m[:card][:sub] %></div>
                  <div class="msg-card-footer">
                    <% if m[:card][:price] %><span class="msg-card-price"><%= m[:card][:price] %></span><% end %>
                    <div class="msg-card-actions">
                      <span class="btn-signal msg-card-cta">"<%= m[:card][:cta] %>"</span>
                      <% if m[:card][:cta2] %><span class="btn-ghost msg-card-cta"><%= m[:card][:cta2] %></span><% end %>
                    </div>
                  </div>
                </div>
              <% end %>

              <div class="msg-time"><%= m[:time] %></div>
            </div>
          </div>
        </div>
      <% end %>

    <% end %>
  </div>

  <!-- INPUT BAR -->
  <div class="convo-input-bar">
    <button class="convo-input-icon" aria-label="Attach">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><circle cx="12" cy="12" r="10"/><path d="M12 8v8M8 12h8"/></svg>
    </button>
    <input type="text" class="convo-input" placeholder="Message...">
    <button class="convo-input-icon" aria-label="Voice">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><rect x="9" y="2" width="6" height="11" rx="3"/><path d="M5 10a7 7 0 0014 0"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
    </button>
    <button class="convo-send">
      <svg viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" width="16" height="16"><path d="M22 2L11 13"/><path d="M22 2L15 22L11 13L2 9z"/></svg>
    </button>
  </div>

</div>
