<div class="auth-page">

  <div class="auth-panel">
    <span class="logo">
      <span class="logo-mark"><span></span><span></span><span></span><span></span></span>
      LE PLUG
    </span>

    <span class="auth-kicker">Nouveau mot de passe</span>
    <h1 class="auth-title">Choisis ton <em>nouveau code</em>.</h1>

    <%= simple_form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "auth-form" }) do |f| %>
      <%= f.error_notification %>

      <%= f.input :reset_password_token, as: :hidden %>
      <%= f.full_error :reset_password_token %>

      <div class="form-inputs">
        <%= f.input :password,
                    label: "Nouveau mot de passe",
                    required: true,
                    autofocus: true,
                    placeholder: "••••••••",
                    hint: ("#{@minimum_password_length} caractères minimum" if @minimum_password_length),
                    input_html: { autocomplete: "new-password" } %>
        <%= f.input :password_confirmation,
                    label: "Confirmer le nouveau mot de passe",
                    required: true,
                    placeholder: "••••••••",
                    input_html: { autocomplete: "new-password" } %>
      </div>

      <%= f.button :submit, "Changer mon mot de passe →", class: "btn-primary auth-submit" %>
    <% end %>

    <div class="auth-links">
      <span><%= link_to "← Retour à la connexion", new_session_path(resource_name) %></span>
    </div>
  </div>
</div>
