<div class="auth-page">

  <div class="auth-panel">
    <span class="logo">
      <span class="logo-mark"><span></span><span></span><span></span><span></span></span>
      LE PLUG
    </span>

    <span class="auth-kicker">Mon compte</span>
    <h1 class="auth-title">Tes <em>informations</em>.</h1>
    <p class="auth-sub">Mets à jour ton email ou ton mot de passe.</p>

    <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "auth-form" }) do |f| %>
      <%= f.error_notification %>

      <div class="form-inputs">
        <%= f.input :email,
            required: true,
            autofocus: true,
            label: "Adresse e-mail",
            placeholder: "ton@email.com" %>

        <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
          <div class="alert" style="position: static; margin: 0 0 14px;">
            En attente de confirmation : <%= resource.unconfirmed_email %>
          </div>
        <% end %>

        <%= f.input :password,
            required: false,
            label: "Nouveau mot de passe",
            placeholder: "••••••••",
            hint: "Laisse vide pour ne pas changer" %>

        <%= f.input :password_confirmation,
            required: false,
            label: "Confirmer le nouveau mot de passe",
            placeholder: "••••••••" %>

        <div class="auth-divider"><span>Confirmation requise</span></div>

        <%= f.input :current_password,
            required: true,
            label: "Mot de passe actuel",
            placeholder: "••••••••",
            hint: "Pour confirmer les modifications" %>
      </div>

      <%= f.button :submit, "Mettre à jour →", class: "btn-primary auth-submit" %>
    <% end %>

    <div class="auth-divider"><span>Zone dangereuse</span></div>

    <div class="auth-danger-zone">
      <%= button_to "Supprimer mon compte", registration_path(resource_name),
          method: :delete,
          data: { turbo_confirm: "Es-tu sûr ? Cette action est irréversible." },
          class: "btn-danger" %>
    </div>

    <div class="auth-links">
      <%= link_to "← Retour à l'accueil", root_path %>
    </div>
  </div>

</div>
