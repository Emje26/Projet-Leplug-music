<div class="cyber-auth-page">

  <!-- Floating music notes background -->
  <div class="cyber-notes-bg">
    <span class="note">♪</span>
    <span class="note">♫</span>
    <span class="note">🎵</span>
    <span class="note">♬</span>
    <span class="note">🎶</span>
    <span class="note">♩</span>
    <span class="note">♪</span>
    <span class="note">♫</span>
    <span class="note">🎵</span>
    <span class="note">♬</span>
  </div>

  <div class="cyber-card">

    <!-- Header -->
    <div class="cyber-header-section">
      <div class="cyber-icon">⚙️</div>
      <h1 class="cyber-title">Mon Profil</h1>
      <p class="cyber-subtitle">Modifie tes <span class="highlight">informations</span></p>
    </div>

    <!-- Form -->
    <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "cyber-form" }) do |f| %>
      <%= f.error_notification %>

      <div class="form-inputs">
        <%= f.input :email,
            required: true,
            autofocus: true,
            label: "Adresse e-mail",
            placeholder: "ton@email.com" %>

        <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
          <p style="color: #00f5ff; font-size: 0.85rem; margin-bottom: 1rem; padding: 0.75rem; background: rgba(0,245,255,0.1); border-radius: 8px;">
            ⏳ En attente de confirmation : <%= resource.unconfirmed_email %>
          </p>
        <% end %>

        <%= f.input :password,
            required: false,
            label: "Nouveau mot de passe",
            placeholder: "••••••••",
            hint: "Laisse vide pour ne pas changer" %>

        <%= f.input :password_confirmation,
            required: false,
            label: "Confirmer le nouveau mot de passe",
            placeholder: "••••••••" %>

        <div class="cyber-divider">
          <span>Confirmation requise</span>
        </div>

        <%= f.input :current_password,
            required: true,
            label: "Mot de passe actuel",
            placeholder: "••••••••",
            hint: "Pour confirmer les modifications" %>
      </div>

      <%= f.button :submit, "Mettre à jour", class: "cyber-btn" %>
    <% end %>

    <!-- Danger zone -->
    <div class="cyber-divider">
      <span>Zone dangereuse</span>
    </div>

    <div style="text-align: center;">
      <%= button_to "Supprimer mon compte", registration_path(resource_name),
          method: :delete,
          data: { confirm: "Es-tu sûr ? Cette action est irréversible.", turbo_confirm: "Es-tu sûr ? Cette action est irréversible." },
          class: "cyber-btn cyber-btn-danger",
          style: "display: inline-block; width: auto; padding: 0.75rem 2rem;" %>
    </div>

    <!-- Links -->
    <div class="cyber-links">
      <%= link_to "← Retour à l'accueil", root_path %>
    </div>

  </div>

</div>
