<div class="auth-page">
  <div class="ambient-bg">
    <div class="gradient-orb gradient-orb-1"></div>
    <div class="gradient-orb gradient-orb-2"></div>
    <div class="gradient-orb gradient-orb-3"></div>
  </div>

  <main class="main-content">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-lg-5 col-md-7 col-sm-10">

          <div class="register-card fade-in-up">
            <div class="card-header text-center">
              <h1 class="card-title">Mon profil</h1>
              <p class="card-subtitle">Modifiez vos informations</p>
            </div>

            <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
              <%= f.error_notification %>

              <div class="form-floating-apple mb-3">
                <%= f.input :email,
                    required: true,
                    autofocus: true,
                    label: false,
                    placeholder: " ",
                    input_html: { class: "form-control-apple" },
                    wrapper: false %>
                <label>Adresse e-mail</label>
                <div class="input-glow"></div>
              </div>

              <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
                <p style="color: #FFD60A; font-size: 0.85rem; margin-bottom: 1rem;">
                  En attente de confirmation : <%= resource.unconfirmed_email %>
                </p>
              <% end %>

              <div class="form-floating-apple mb-3">
                <%= f.input :password,
                    required: false,
                    label: false,
                    placeholder: " ",
                    hint: false,
                    input_html: { class: "form-control-apple", autocomplete: "new-password" },
                    wrapper: false %>
                <label>Nouveau mot de passe</label>
                <div class="input-glow"></div>
              </div>
              <p style="color: rgba(255,255,255,0.4); font-size: 0.8rem; margin-top: -0.5rem; margin-bottom: 1rem;">
                Laissez vide si vous ne voulez pas le changer
              </p>

              <div class="form-floating-apple mb-3">
                <%= f.input :password_confirmation,
                    required: false,
                    label: false,
                    placeholder: " ",
                    input_html: { class: "form-control-apple", autocomplete: "new-password" },
                    wrapper: false %>
                <label>Confirmer le nouveau mot de passe</label>
                <div class="input-glow"></div>
              </div>

              <div class="form-floating-apple mb-4">
                <%= f.input :current_password,
                    required: true,
                    label: false,
                    placeholder: " ",
                    hint: false,
                    input_html: { class: "form-control-apple", autocomplete: "current-password" },
                    wrapper: false %>
                <label>Mot de passe actuel</label>
                <div class="input-glow"></div>
              </div>
              <p style="color: rgba(255,255,255,0.4); font-size: 0.8rem; margin-top: -0.5rem; margin-bottom: 1.5rem;">
                Requis pour confirmer vos modifications
              </p>

              <%= f.button :submit, "Mettre à jour", class: "btn-apple-primary w-100" %>
            <% end %>

            <div class="divider"><span>Zone dangereuse</span></div>

            <div class="text-center">
              <%= button_to "Supprimer mon compte", registration_path(resource_name),
                  method: :delete,
                  data: { confirm: "Êtes-vous sûr ?", turbo_confirm: "Êtes-vous sûr ?" },
                  class: "btn-delete-account" %>
            </div>

            <p class="text-center mt-4">
              <%= link_to "← Retour", :back, style: "color: #0A84FF;" %>
            </p>
          </div>

        </div>
      </div>
    </div>
  </main>
</div>
