<div class="auth-page">

  <aside class="auth-poster">
    <div class="poster-top">
      <span class="brand-dot"></span>
      <span class="brand-name">LE PLUG</span>
      <span class="catalog">C/O "MUSIC" — V.1.0</span>
    </div>

    <div class="poster-mid">
      <span class="poster-catalog">№ 002 / NEW ARTIST</span>
      <h2 class="poster-title">
        PLUG<span class="slash">.</span><br>
        IN<span class="slash">/</span>
      </h2>
      <p class="poster-sub">
        Rejoins 2.1K artistes déjà connectés. Upload un son, ajoute ta bio,
        et commence à te "plug" avec la scène. Gratuit, pour toujours.
      </p>
    </div>

    <div class="poster-bottom">
      <span>"FOR ARTISTS, BY ARTISTS"</span>
      <span>— <%= Date.today.year %> —</span>
    </div>
  </aside>

  <div class="auth-panel">
    <div class="auth-mobile-brand">
      <span class="brand-dot"></span>
      <span class="brand-name">LE PLUG</span>
    </div>

    <div class="auth-heading">
      <span class="h-kicker">NEW</span>
      <h1>NEW<br>PLUG.</h1>
      <p>Crée ton compte en 30 secondes. On ne demande rien de plus que l'essentiel.</p>
    </div>

    <div class="auth-tabs">
      <%= link_to "SE CONNECTER", new_session_path(resource_name), class: "auth-tab" %>
      <span class="auth-tab active">CRÉER UN COMPTE</span>
    </div>

    <% if flash[:alert] %>
      <div class="alert alert-danger"><%= flash[:alert] %></div>
    <% end %>

    <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "auth-form" }) do |f| %>
      <%= f.error_notification %>

      <div class="form-inputs">
        <%= f.input :email,
            required: true,
            autofocus: true,
            autocomplete: "email",
            label: "EMAIL",
            placeholder: "ton@email.com" %>

        <%= f.input :password,
            required: true,
            autocomplete: "new-password",
            label: "MOT DE PASSE",
            placeholder: "••••••••",
            hint: "6 caractères minimum" %>

        <%= f.input :password_confirmation,
            required: true,
            autocomplete: "new-password",
            label: "CONFIRMATION",
            placeholder: "••••••••" %>
      </div>

      <%= f.button :submit, "CRÉER MON COMPTE →", class: "auth-submit" %>
    <% end %>

    <div class="auth-links">
      <span>Déjà inscrit ? <%= link_to "\"LOGIN\" →", new_session_path(resource_name) %></span>
    </div>

    <div class="auth-badge">
      <span class="dot"></span>
      INSCRIPTION "SÉCURISÉE"
    </div>
  </div>
</div>
