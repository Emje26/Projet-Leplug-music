<div class="cyber-auth-page">

  <!-- Floating music notes background -->
  <div class="cyber-notes-bg">
    <span class="note">♪</span>
    <span class="note">♫</span>
    <span class="note">🎵</span>
    <span class="note">♬</span>
    <span class="note">🎶</span>
    <span class="note">♩</span>
    <span class="note">♪</span>
    <span class="note">♫</span>
    <span class="note">🎵</span>
    <span class="note">♬</span>
  </div>

  <div class="cyber-card">

    <!-- Header -->
    <div class="cyber-header-section">
      <div class="cyber-icon">🎧</div>
      <h1 class="cyber-title">Rejoins Le Plug</h1>
      <p class="cyber-subtitle">Connecte-toi à la <span class="highlight">scène musicale</span></p>
    </div>

    <!-- Tabs -->
    <div class="cyber-tabs">
      <%= link_to "Se connecter", new_session_path(resource_name), class: "cyber-tab" %>
      <div class="cyber-tab active">Créer un compte</div>
    </div>

    <!-- Flash messages -->
    <% if flash[:alert] %>
      <div class="alert alert-danger" style="background: rgba(255,71,87,0.1); border: 1px solid #ff4757; border-radius: 10px; padding: 1rem; margin-bottom: 1rem; color: #ff6b7a;">
        <%= flash[:alert] %>
      </div>
    <% end %>

    <!-- Form -->
    <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "cyber-form" }) do |f| %>
      <%= f.error_notification %>

      <div class="form-inputs">
        <%= f.input :email,
            required: true,
            autofocus: true,
            autocomplete: "email",
            label: "Adresse e-mail",
            placeholder: "ton@email.com" %>

        <%= f.input :password,
            required: true,
            autocomplete: "new-password",
            label: "Mot de passe",
            placeholder: "••••••••",
            hint: "6 caractères minimum" %>

        <%= f.input :password_confirmation,
            required: true,
            autocomplete: "new-password",
            label: "Confirmer le mot de passe",
            placeholder: "••••••••" %>
      </div>

      <%= f.button :submit, "Créer mon compte", class: "cyber-btn" %>
    <% end %>

    <!-- Links -->
    <div class="cyber-links">
      <span>Déjà inscrit ?</span>
      <%= link_to "Connecte-toi", new_session_path(resource_name) %>
    </div>

    <!-- Security badge -->
    <div class="cyber-badge">
      <span class="badge-icon">🔒</span>
      <span class="badge-text">Connexion sécurisée</span>
    </div>

  </div>

</div>
