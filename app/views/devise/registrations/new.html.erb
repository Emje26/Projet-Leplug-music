<div class="auth-page">

  <div class="auth-panel">
    <span class="logo">
      <span class="logo-mark"><span></span><span></span><span></span><span></span></span>
      LE PLUG
    </span>

    <span class="auth-kicker">Inscription</span>
    <h1 class="auth-title">Ton prochain son <em>commence ici</em>.</h1>
    <p class="auth-sub">Crée ton compte en 30 secondes. Gratuit, pour toujours.</p>

    <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "auth-form" }) do |f| %>
      <%= f.error_notification %>

      <div class="form-inputs">
        <%= f.input :email,
            required: true,
            autofocus: true,
            autocomplete: "email",
            label: "Email",
            placeholder: "ton@email.com" %>

        <%= f.input :password,
            required: true,
            autocomplete: "new-password",
            label: "Mot de passe",
            placeholder: "••••••••",
            hint: "6 caractères minimum" %>

        <%= f.input :password_confirmation,
            required: true,
            autocomplete: "new-password",
            label: "Confirmer le mot de passe",
            placeholder: "••••••••" %>
      </div>

      <%= f.button :submit, "Créer mon compte →", class: "btn-primary auth-submit" %>
    <% end %>

    <div class="auth-links">
      <span>Déjà inscrit ? <%= link_to "Se connecter →", new_session_path(resource_name) %></span>
    </div>
  </div>
</div>
