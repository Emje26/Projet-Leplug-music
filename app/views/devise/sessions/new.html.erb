<div class="auth-page">

  <div class="auth-panel">
    <div class="auth-starburst">
      <%= render "shared/starburst", size: :medium %>
    </div>

    <h1 class="auth-title">LE PLUG</h1>
    <%= render "shared/drip" %>

    <p class="auth-sub">Entre tes identifiants pour accéder à ton feed.</p>

    <% if flash[:alert] %>
      <div class="alert alert-danger"><%= flash[:alert] %></div>
    <% end %>

    <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "auth-form" }) do |f| %>
      <div class="form-inputs">
        <%= f.input :email,
            required: true,
            autofocus: true,
            label: false,
            placeholder: "Email",
            input_html: { autocomplete: "email" } %>

        <%= f.input :password,
            required: true,
            label: false,
            placeholder: "Mot de passe",
            input_html: { autocomplete: "current-password" } %>

        <% if devise_mapping.rememberable? %>
          <div class="boolean">
            <%= f.input :remember_me, as: :boolean, label: "Se souvenir" %>
          </div>
        <% end %>
      </div>

      <%= f.button :submit, "\"SE CONNECTER\"", class: "btn-signal auth-submit" %>
    <% end %>

    <div class="auth-links">
      <%= link_to "Mot de passe oublié ?", new_password_path(resource_name) %>
      <span>Pas encore inscrit ? <%= link_to "Créer un compte →", new_registration_path(resource_name) %></span>
    </div>
  </div>
</div>
