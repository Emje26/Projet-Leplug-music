<div class="cyber-auth-page">

  <!-- Floating music notes background -->
  <div class="cyber-notes-bg">
    <span class="note">♪</span>
    <span class="note">♫</span>
    <span class="note">🎵</span>
    <span class="note">♬</span>
    <span class="note">🎶</span>
    <span class="note">♩</span>
    <span class="note">♪</span>
    <span class="note">♫</span>
    <span class="note">🎵</span>
    <span class="note">♬</span>
  </div>

  <div class="cyber-card">

    <!-- Header -->
    <div class="cyber-header-section">
      <div class="cyber-icon">🔐</div>
      <h1 class="cyber-title">Connexion</h1>
      <p class="cyber-subtitle">Accède à <span class="highlight">Le Plug</span></p>
    </div>

    <!-- Tabs -->
    <div class="cyber-tabs">
      <div class="cyber-tab active">Se connecter</div>
      <%= link_to "Créer un compte", new_registration_path(resource_name), class: "cyber-tab" %>
    </div>

    <!-- Flash messages -->
    <% if flash[:alert] %>
      <div class="alert alert-danger" style="background: rgba(255,71,87,0.1); border: 1px solid #ff4757; border-radius: 10px; padding: 1rem; margin-bottom: 1rem; color: #ff6b7a;">
        <%= flash[:alert] %>
      </div>
    <% end %>

    <!-- Form -->
    <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "cyber-form" }) do |f| %>

      <div class="form-inputs">
        <%= f.input :email,
            required: true,
            autofocus: true,
            label: "Adresse e-mail",
            placeholder: "ton@email.com",
            input_html: { autocomplete: "email" } %>

        <%= f.input :password,
            required: true,
            label: "Mot de passe",
            placeholder: "••••••••",
            input_html: { autocomplete: "current-password" } %>

        <% if devise_mapping.rememberable? %>
          <div class="boolean">
            <%= f.input :remember_me, as: :boolean, label: "Se souvenir de moi" %>
          </div>
        <% end %>
      </div>

      <%= f.button :submit, "Se connecter", class: "cyber-btn" %>
    <% end %>

    <!-- Links -->
    <div class="cyber-links">
      <%= link_to "Mot de passe oublié ?", new_password_path(resource_name) %>
      <br><br>
      <span>Pas encore inscrit ?</span>
      <%= link_to "Créer un compte", new_registration_path(resource_name) %>
    </div>

    <!-- Security badge -->
    <div class="cyber-badge">
      <span class="badge-icon">🛡️</span>
      <span class="badge-text">Connexion sécurisée</span>
    </div>

  </div>

</div>
