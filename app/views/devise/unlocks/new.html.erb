<div class="auth-page">

  <div class="auth-panel">
    <span class="logo">
      <span class="logo-mark"><span></span><span></span><span></span><span></span></span>
      LE PLUG
    </span>

    <span class="auth-kicker">Compte verrouillé</span>
    <h1 class="auth-title">Renvoyer les instructions de <em>déverrouillage</em>.</h1>

    <%= simple_form_for(resource, as: resource_name, url: unlock_path(resource_name), html: { method: :post, class: "auth-form" }) do |f| %>
      <%= f.error_notification %>
      <%= f.full_error :unlock_token %>

      <div class="form-inputs">
        <%= f.input :email,
                    required: true,
                    autofocus: true,
                    label: "Email",
                    placeholder: "ton@email.com",
                    input_html: { autocomplete: "email" } %>
      </div>

      <%= f.button :submit, "Renvoyer →", class: "btn-primary auth-submit" %>
    <% end %>

    <div class="auth-links">
      <span><%= link_to "← Retour à la connexion", new_session_path(resource_name) %></span>
    </div>
  </div>
</div>
