<%# Logged-in users are redirected to search_path by HomeController#index.
    This template is the landing page for anonymous visitors only. %>

<div class="plug-landing">
  <!-- Clouds behind everything -->
  <%= render "shared/clouds" %>

  <header class="landing-topbar">
    <span class="lt-brand" style="animation: flicker 6s ease-in-out infinite;">LE PLUG</span>
    <span class="lt-right"><%= Date.today.year %></span>
  </header>

  <section class="landing-body">
    <!-- Starburst behind the title -->
    <div class="landing-starburst">
      <%= render "shared/starburst", size: :large %>
    </div>

    <h1 class="landing-title">LE PLUG</h1>
    <%= render "shared/drip" %>

    <p class="landing-sub">
      La musique. Les studios. Les talents.<br>
      <strong>Tout connecté.</strong>
    </p>

    <div class="landing-actions">
      <%= link_to new_user_registration_path, class: "btn-signal" do %>
        "CRÉER UN COMPTE"
      <% end %>
      <%= link_to new_user_session_path, class: "btn-ghost" do %>
        "SE CONNECTER"
      <% end %>
    </div>
  </section>

  <footer class="landing-footer">
    <span class="q">MADE IN LE WAGON</span>
    <span style="color: var(--accent);">● 2.1K ARTISTS PLUGGED</span>
  </footer>
</div>
