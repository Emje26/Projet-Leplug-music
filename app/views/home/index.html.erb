<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Kitchen Guru - Your Meal Planner</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,400&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    /* ===========================================
       🍳 KITCHEN GURU - MOCHA BROWN EDITION
       Same palette as recipes pages
       =========================================== */

    :root {
      /* Mocha Brown Palette - Deliberately darker to remain mocha on brightened screens */
      --mocha-darkest: #2c1810;
      --mocha-dark: #3d251a;
      --mocha-medium: #4a2c1c;
      --mocha-base: #5c3a2e;
      --mocha-light: #7a5244;
      --mocha-lighter: #9b7566;

      /* Accent Colors - Warm Terracotta & Caramel */
      --accent-primary: #c4704a;
      --accent-primary-dark: #a85f3d;
      --accent-secondary: #d4a574;
      --accent-tertiary: #8b5a3c;

      /* Secondary - Sage Green */
      --secondary: #8FA57E;
      --secondary-dark: #6B8560;
      --secondary-light: #B5C9A8;

      /* Background Colors */
      --bg-primary: #f8f4f1;
      --bg-secondary: #f0e9e4;
      --bg-tertiary: #e8dfd8;
      --bg-card: #ffffff;

      /* Border */
      --border-color: rgba(92, 58, 46, 0.12);

      /* Shadows */
      --shadow-soft: 0 2px 8px rgba(44, 24, 16, 0.06);
      --shadow-medium: 0 8px 24px rgba(44, 24, 16, 0.08);
      --shadow-card: 0 4px 20px rgba(44, 24, 16, 0.06);
    }

    *, *::before, *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    html {
      font-size: 16px;
      scroll-behavior: smooth;
    }

    body {
      font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, sans-serif;
      background: var(--bg-primary);
      color: var(--mocha-darkest);
      min-height: 100vh;
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    /* ===========================================
       🌿 BACKGROUND - Naturel et lumineux
       =========================================== */
    .bg-natural {
      background:
        radial-gradient(ellipse 120% 80% at 20% 10%, rgba(143, 165, 126, 0.12) 0%, transparent 50%),
        radial-gradient(ellipse 100% 60% at 85% 90%, rgba(196, 112, 74, 0.08) 0%, transparent 40%),
        linear-gradient(180deg, var(--bg-primary) 0%, var(--bg-secondary) 100%);
      position: relative;
      overflow: hidden;
    }

    /* Subtle organic shapes */
    .bg-natural::before {
      content: "";
      position: absolute;
      width: 400px;
      height: 400px;
      border-radius: 60% 40% 50% 50% / 50% 60% 40% 50%;
      background: linear-gradient(135deg, rgba(143, 165, 126, 0.06) 0%, transparent 60%);
      top: -100px;
      right: -80px;
      animation: organic-float 20s ease-in-out infinite;
    }

    .bg-natural::after {
      content: "";
      position: absolute;
      width: 300px;
      height: 300px;
      border-radius: 40% 60% 50% 50% / 60% 40% 60% 40%;
      background: linear-gradient(225deg, rgba(212, 165, 116, 0.05) 0%, transparent 60%);
      bottom: -50px;
      left: -60px;
      animation: organic-float 25s ease-in-out infinite reverse;
    }

    @keyframes organic-float {
      0%, 100% { transform: translate(0, 0) rotate(0deg) scale(1); }
      33% { transform: translate(20px, -15px) rotate(5deg) scale(1.02); }
      66% { transform: translate(-10px, 10px) rotate(-3deg) scale(0.98); }
    }

    /* ===========================================
       🏠 HOMEPAGE LAYOUT
       =========================================== */
    .homepage {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem 1.5rem;
      position: relative;
      z-index: 1;
    }

    .homepage__container {
      width: 100%;
      max-width: 400px;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1.5rem;
    }

    /* ===========================================
       🎪 LOGO
       =========================================== */
    .logo {
      display: flex;
      align-items: center;
      gap: 0.625rem;
      padding: 0.75rem 1.25rem;
      background: var(--bg-card);
      border-radius: 100px;
      box-shadow: var(--shadow-soft);
      border: 1px solid var(--border-color);
    }

    .logo__icon {
      width: 36px;
      height: 36px;
      background: linear-gradient(135deg, var(--mocha-base) 0%, var(--mocha-light) 100%);
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.25rem;
    }

    .logo__text {
      font-family: 'Fraunces', Georgia, serif;
      font-size: 1.125rem;
      font-weight: 600;
      color: var(--mocha-dark);
      letter-spacing: -0.02em;
    }

    /* ===========================================
       📦 MAIN CARD
       =========================================== */
    .card {
      width: 100%;
      background: var(--bg-card);
      border-radius: 28px;
      padding: 2.5rem 2rem;
      box-shadow: var(--shadow-card);
      border: 1px solid var(--border-color);
      text-align: center;
      position: relative;
      overflow: hidden;
    }

    /* Mocha gradient top accent */
    .card::before {
      content: "";
      position: absolute;
      top: 0;
      left: 50%;
      transform: translateX(-50%);
      width: 60px;
      height: 4px;
      background: linear-gradient(90deg, var(--mocha-base) 0%, var(--accent-primary) 100%);
      border-radius: 0 0 4px 4px;
    }

    /* ===========================================
       📝 CONTENT
       =========================================== */
    .content {
      margin-bottom: 2rem;
    }

    .title {
      font-family: 'Fraunces', Georgia, serif;
      font-size: 1.875rem;
      font-weight: 600;
      line-height: 1.25;
      color: var(--mocha-darkest);
      margin-bottom: 1rem;
      letter-spacing: -0.02em;
    }

    .title__highlight {
      color: var(--accent-primary);
      font-style: italic;
    }

    .subtitle {
      font-size: 1rem;
      line-height: 1.6;
      color: var(--mocha-light);
      font-weight: 400;
    }

    /* ===========================================
       🎈 DECORATIVE ILLUSTRATIONS
       =========================================== */
    .decorations {
      display: flex;
      justify-content: center;
      gap: 0.75rem;
      margin-bottom: 2rem;
    }

    .deco-item {
      width: 52px;
      height: 52px;
      background: var(--bg-secondary);
      border-radius: 16px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.5rem;
      border: 1px solid var(--border-color);
      transition: all 0.3s ease;
    }

    .deco-item:hover {
      transform: translateY(-4px) rotate(5deg);
      box-shadow: var(--shadow-soft);
      border-color: rgba(196, 112, 74, 0.3);
    }

    .deco-item:nth-child(2) { animation-delay: 0.1s; }
    .deco-item:nth-child(3) { animation-delay: 0.2s; }
    .deco-item:nth-child(4) { animation-delay: 0.3s; }

    /* ===========================================
       🔘 CTA BUTTON
       =========================================== */
    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.625rem;
      width: 100%;
      padding: 1rem 1.5rem;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 1rem;
      font-weight: 600;
      text-decoration: none;
      border: none;
      border-radius: 16px;
      cursor: pointer;
      transition: all 0.3s cubic-bezier(0.22, 1, 0.36, 1);
      position: relative;
      overflow: hidden;
    }

    .btn--primary {
      background: linear-gradient(135deg, var(--accent-primary) 0%, var(--accent-primary-dark) 100%);
      color: white;
      box-shadow:
        0 4px 12px rgba(196, 112, 74, 0.3),
        inset 0 1px 0 rgba(255,255,255,0.15);
    }

    .btn--primary:hover {
      transform: translateY(-2px);
      box-shadow:
        0 8px 20px rgba(196, 112, 74, 0.35),
        inset 0 1px 0 rgba(255,255,255,0.15);
    }

    .btn--primary:active {
      transform: translateY(0);
    }

    .btn svg {
      transition: transform 0.3s ease;
    }

    .btn:hover svg {
      transform: translateX(3px);
    }

    /* ===========================================
       🔗 SECONDARY LINK
       =========================================== */
    .link-secondary {
      display: block;
      margin-top: 1.25rem;
      font-size: 0.9rem;
      color: var(--mocha-lighter);
      text-decoration: none;
      transition: color 0.2s ease;
    }

    .link-secondary span {
      color: var(--accent-primary);
      font-weight: 500;
    }

    .link-secondary:hover {
      color: var(--mocha-base);
    }

    .link-secondary:hover span {
      text-decoration: underline;
    }

    /* ===========================================
       💡 FEATURE HINTS
       =========================================== */
    .hints {
      display: flex;
      justify-content: center;
      gap: 1.5rem;
      margin-top: 1.5rem;
    }

    .hint {
      display: flex;
      align-items: center;
      gap: 0.375rem;
      font-size: 0.8rem;
      color: var(--mocha-lighter);
    }

    .hint__icon {
      width: 18px;
      height: 18px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .hint__icon svg {
      width: 14px;
      height: 14px;
      stroke: var(--mocha-base);
    }

    /* ===========================================
       🌿 BOTTOM BADGE
       =========================================== */
    .badge {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.5rem 1rem;
      background: var(--bg-card);
      border-radius: 100px;
      box-shadow: var(--shadow-soft);
      font-size: 0.8rem;
      color: var(--mocha-base);
      border: 1px solid var(--border-color);
    }

    .badge__dot {
      width: 8px;
      height: 8px;
      background: var(--mocha-base);
      border-radius: 50%;
      animation: pulse-dot 2s ease-in-out infinite;
    }

    @keyframes pulse-dot {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.6; transform: scale(0.85); }
    }

    /* ===========================================
       ✨ ANIMATIONS
       =========================================== */
    @keyframes fadeInUp {
      from {
        opacity: 0;
        transform: translateY(20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .animate-in {
      opacity: 0;
      animation: fadeInUp 0.6s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    }

    .delay-1 { animation-delay: 0.1s; }
    .delay-2 { animation-delay: 0.2s; }
    .delay-3 { animation-delay: 0.3s; }
    .delay-4 { animation-delay: 0.4s; }
    .delay-5 { animation-delay: 0.5s; }

    /* ===========================================
       📱 RESPONSIVE
       =========================================== */
    @media (max-width: 380px) {
      .homepage {
        padding: 1.5rem 1rem;
      }

      .card {
        padding: 2rem 1.5rem;
        border-radius: 24px;
      }

      .title {
        font-size: 1.625rem;
      }

      .decorations {
        gap: 0.5rem;
      }

      .deco-item {
        width: 46px;
        height: 46px;
        font-size: 1.25rem;
      }
    }

    @media (min-width: 768px) {
      .homepage__container {
        max-width: 440px;
      }

      .card {
        padding: 3rem 2.5rem;
      }

      .title {
        font-size: 2.125rem;
      }
    }
  </style>
</head>
<body>
  <main class="homepage bg-natural">
    <div class="homepage__container">

      <!-- Logo -->
      <div class="logo animate-in">
        <div class="logo__icon">🥗</div>
        <span class="logo__text">Kitchen Guru</span>
      </div>

      <!-- Main Card -->
      <div class="card animate-in delay-1">

        <!-- Content -->
        <div class="content">
          <h1 class="title animate-in delay-2">
            Your easy,<br>
            <span class="title__highlight">affordable</span> meal planner
          </h1>

          <p class="subtitle animate-in delay-3">
            Personalize your profile to get a custom meal plan tailored just for you
          </p>
        </div>

        <!-- Decorative food icons -->
        <div class="decorations animate-in delay-3">
          <div class="deco-item">🥑</div>
          <div class="deco-item">🍲</div>
          <div class="deco-item">🥕</div>
          <div class="deco-item">🍳</div>
        </div>

        <!-- CTA -->
        <a href="#create" class="btn btn--primary animate-in delay-4">
          <span>Create recipe</span>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>

        <!-- Secondary link -->
        <a href="#login" class="link-secondary animate-in delay-4">
          Already have an account? <span>Sign in</span>
        </a>

        <!-- Feature hints -->
        <div class="hints animate-in delay-5">
          <div class="hint">
            <span class="hint__icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                <polyline points="22 4 12 14.01 9 11.01"/>
              </svg>
            </span>
            <span>Free to start</span>
          </div>
          <div class="hint">
            <span class="hint__icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              </svg>
            </span>
            <span>No credit card</span>
          </div>
        </div>

      </div>

      <!-- Bottom badge -->
      <div class="badge animate-in delay-5">
        <span class="badge__dot"></span>
        <span>Trusted by 10k+ home cooks</span>
      </div>

    <div class="d-flex align-items-center justify-content-center mb-4">
      <%= image_tag "logo.png", alt: "Kitchen Guru Logo", width: 60, class: "rounded-circle shadow me-3" %>
      <div>
        <h1 class="h1 fw-bold mb-0" style="font-family: 'Nunito', 'Helvetica', sans-serif; color: #333;">
          Kitchen Guru
        </h1>
        <p class="text-muted mb-0" style="font-size: 1.1rem;">
          Your gut's new bestie
        </p>
      </div>
    </div>
  </main>
</body>
</html>
