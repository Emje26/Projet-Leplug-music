<% if user_signed_in? %>
  <div class="feed-page">

    <!-- Stories Section -->
    <section class="stories-section">
      <div class="stories-scroll">
        <!-- Your Story -->
        <div class="story-item your-story">
          <div class="story-avatar">
            <span>+</span>
          </div>
          <span class="story-name">Votre story</span>
        </div>

        <!-- Other Stories -->
        <% 8.times do |i| %>
          <div class="story-item">
            <div class="story-avatar <%= ['gradient-1', 'gradient-2', 'gradient-3', 'gradient-1', 'gradient-2', 'gradient-3', 'gradient-1', 'gradient-2'][i] %>">
              <div class="story-avatar-inner">
                <%= ['🎤', '🎸', '🎹', '🥁', '🎧', '🎵', '🎷', '🎻'][i] %>
              </div>
            </div>
            <span class="story-name"><%= ['artist_1', 'prod_jay', 'melodie', 'drum_king', 'dj_max', 'wave_', 'jazzy', 'cello'][i] %></span>
          </div>
        <% end %>
      </div>
    </section>

    <!-- Pour vous Section (Spotify-style cards) -->
    <section class="spotify-section">
      <h2 class="section-title">Pour vous</h2>
      <div class="spotify-scroll">
        <% 6.times do |i| %>
          <div class="spotify-card">
            <div class="spotify-cover">
              <div class="cover-gradient gradient-<%= (i % 3) + 1 %>">
                <%= ['🎤', '🔥', '💜', '⚡', '🌙', '✨'][i] %>
              </div>
              <div class="play-btn">▶</div>
            </div>
            <p class="spotify-title"><%= ['Nouveaux sons', 'Tendances', 'Découvertes', 'Fresh Beats', 'Night Vibes', 'Énergie'][i] %></p>
            <p class="spotify-subtitle"><%= ['Mix personnalisé', 'Ce qui buzz', 'Pour toi', 'Producteurs locaux', 'Chill & Relax', 'Motivation'][i] %></p>
          </div>
        <% end %>
      </div>
    </section>

    <!-- Shorts/Reels Feed (Vertical scroll cards) -->
    <section class="shorts-section">
      <h2 class="section-title">En ce moment 🔥</h2>
      <div class="shorts-grid">
        <% 6.times do |i| %>
          <div class="short-card">
            <div class="short-preview">
              <div class="short-gradient gradient-<%= (i % 6) + 1 %>">
                <span class="short-icon"><%= ['🎤', '🎹', '🎸', '🥁', '🎧', '🔊'][i] %></span>
              </div>
              <div class="short-overlay">
                <div class="short-info">
                  <span class="short-artist">@artist_<%= i + 1 %></span>
                  <span class="short-song">Track Title #<%= i + 1 %></span>
                </div>
                <div class="short-stats">
                  <span>▶ <%= (i + 1) * 12 %>K</span>
                </div>
              </div>
              <div class="short-play">▶</div>
            </div>
          </div>
        <% end %>
      </div>
    </section>

    <!-- Artistes récents -->
    <section class="spotify-section">
      <h2 class="section-title">Artistes récents</h2>
      <div class="artists-scroll">
        <% 8.times do |i| %>
          <div class="artist-circle">
            <div class="artist-avatar">
              <%= ['👨‍🎤', '👩‍🎤', '🧑‍🎤', '🎙️', '🎵', '🎶', '🎼', '🎹'][i] %>
            </div>
            <span class="artist-name"><%= ['MC Flow', 'Luna', 'Prod X', 'Jay B', 'Melodie', 'Wave', 'Tempo', 'Keys'][i] %></span>
          </div>
        <% end %>
      </div>
    </section>

    <!-- More Shorts -->
    <section class="shorts-section">
      <h2 class="section-title">Découvrir</h2>
      <div class="shorts-grid">
        <% 4.times do |i| %>
          <div class="short-card">
            <div class="short-preview">
              <div class="short-gradient gradient-<%= (i % 6) + 4 %>">
                <span class="short-icon"><%= ['🌟', '💫', '🔥', '⚡'][i] %></span>
              </div>
              <div class="short-overlay">
                <div class="short-info">
                  <span class="short-artist">@new_talent_<%= i + 1 %></span>
                  <span class="short-song">Nouveau son</span>
                </div>
                <div class="short-stats">
                  <span>▶ <%= (i + 1) * 5 %>K</span>
                </div>
              </div>
              <div class="short-play">▶</div>
            </div>
          </div>
        <% end %>
      </div>
    </section>

    <div class="bottom-spacer"></div>
  </div>

  <!-- Bottom Navigation Bar -->
  <nav class="bottom-nav">
    <%= link_to root_path, class: "nav-item active" do %>
      <span class="nav-icon">🏠</span>
      <span class="nav-label">Home</span>
    <% end %>

    <%= link_to chats_path, class: "nav-item" do %>
      <span class="nav-icon">💬</span>
      <span class="nav-label">Chat</span>
    <% end %>

    <%= link_to profile_path, class: "nav-item" do %>
      <span class="nav-icon">👤</span>
      <span class="nav-label">Profile</span>
    <% end %>
  </nav>

<% else %>
  <!-- ========== LANDING PAGE - NOT LOGGED IN ========== -->
  <div class="homepage-root bg-natural">
    <div class="d-flex flex-column justify-content-center align-items-center min-vh-100 py-5">

      <!-- Phrase qui apparaît -->
      <div clas="piano-phrase-container">
        <p class="piano-phrase" data-phrase="1">Découvre des nouveaux artistes</p>
        <p class="piano-phrase" data-phrase="2">Fais-toi connaître</p>
        <p class="piano-phrase" data-phrase="3">Contacte des ingénieurs son</p>
        <p class="piano-phrase" data-phrase="4">Partage ta musique</p>
        <p class="piano-phrase" data-phrase="5">Collabore avec des producteurs</p>
        <p class="piano-phrase" data-phrase="6">Trouve ton prochain feat</p>
        <p class="piano-phrase" data-phrase="7">Booste ta carrière</p>
      </div>

      <!-- Piano -->
      <div class="piano">
        <div class="piano-keys">
          <div class="key white" data-note="1"></div>
          <div class="key white" data-note="2"></div>
          <div class="key white" data-note="3"></div>
          <div class="key white" data-note="4"></div>
          <div class="key white" data-note="5"></div>
          <div class="key white" data-note="6"></div>
          <div class="key white" data-note="7"></div>
          <div class="key black" data-note="1" style="left: 45px;"></div>
          <div class="key black" data-note="2" style="left: 105px;"></div>
          <div class="key black" data-note="4" style="left: 225px;"></div>
          <div class="key black" data-note="5" style="left: 285px;"></div>
          <div class="key black" data-note="6" style="left: 345px;"></div>
        </div>
        <div class="piano-body"></div>
      </div>

      <!-- Logo et contenu -->
      <div class="piano-content mt-5">
        <div class="d-flex align-items-center justify-content-center mb-4">
          <%= image_tag "logo.png", alt: "Le Plug Logo", width: 60, class: "rounded-circle shadow me-3" %>
          <div>
            <h1 class="h1 fw-bold mb-0 text-glow">Le plug</h1>
            <p class="text-muted-cyber mb-0">Your music network</p>
          </div>
        </div>

        <%= link_to "Let's plug in!", new_user_session_path, class: "btn-cyber mt-4" %>
      </div>

    </div>
  </div>
<% end %>
