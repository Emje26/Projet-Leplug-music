<!DOCTYPE html>
<html>
  <head>
    <title>Le Plug</title>
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-dark">
    <%= link_to "Skip to main content", "#main-content", class: "visually-hidden-focusable" %>

    <% # Hide navbar when logged in user is on home page (feed page has its own bottom nav) %>
    <% unless user_signed_in? && controller_name == 'home' && action_name == 'index' %>
      <header class="cyber-header">
        <%= render "shared/navbar" %>
      </header>
    <% end %>

    <main id="main-content" class="">
      <div class="">

        <% if notice %>
          <div class="alert alert-primary border-0 rounded-3 shadow-sm py-2 px-3 mb-3 small">
            <%= notice %>
          </div>
        <% end %>

        <% if alert %>
          <div class="alert alert-danger border-0 rounded-3 shadow-sm py-2 px-3 mb-3 small">
            <%= alert %>
          </div>
        <% end %>

        <%= yield %>
      </div>
    </main>
  </body>
</html>
