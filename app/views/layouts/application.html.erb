<!DOCTYPE html>
<html lang="fr">
  <head>
    <title>Le Plug — c/o Music</title>
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="theme-color" content="#0A0A0A">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-dark">
    <%= link_to "Skip to main content", "#main-content", class: "visually-hidden-focusable" %>

    <% # Hide navbar when in the logged-in app shell — those pages have their own headers. %>
    <% show_global_nav = !user_signed_in? && !(controller_name == 'home' && action_name == 'index') && !(controller_path.start_with?('devise')) %>
    <% if show_global_nav %>
      <%= render "shared/navbar" %>
    <% end %>

    <main id="main-content">
      <% if notice %>
        <div class="alert alert-primary"><%= notice %></div>
      <% end %>

      <% if alert %>
        <div class="alert alert-danger"><%= alert %></div>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>
