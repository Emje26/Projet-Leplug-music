<!DOCTYPE html>
<html lang="fr">
  <head>
    <title>Le Plug — c/o Music</title>
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover, user-scalable=no">
    <meta name="theme-color" content="#2C2926">
    <link rel="manifest" href="/manifest.json">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <link rel="apple-touch-icon" href="/icon-192.png">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-dark">
    <%= link_to "Skip to main content", "#main-content", class: "visually-hidden-focusable" %>

    <%
      # Global top navbar is only rendered for anonymous visitors, and only
      # outside of the landing page, devise flows and the (rare) logged-out
      # feed fallback. Logged-in users get per-screen headers.
      on_landing = controller_name == 'home' && action_name == 'index'
      in_devise  = controller_path.start_with?('devise')
      show_global_nav = !user_signed_in? && !on_landing && !in_devise
    %>
    <% if show_global_nav %>
      <%= render "shared/navbar" %>
    <% end %>

    <main id="main-content">
      <% if notice %>
        <div class="alert alert-primary"><%= notice %></div>
      <% end %>

      <% if alert %>
        <div class="alert alert-danger"><%= alert %></div>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>
