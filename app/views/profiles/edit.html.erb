<div class="settings-page">

  <header class="settings-header">
    <%= link_to profile_path, class: "back-btn", "aria-label": "Retour au profil" do %>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="16" height="16">
        <path d="M15 6l-6 6 6 6"/>
      </svg>
    <% end %>
    <div class="settings-title-wrap">
      <h1 class="settings-title">Modifier le profil</h1>
      <span class="settings-sub">Infos publiques</span>
    </div>
    <span class="header-spacer"></span>
  </header>

  <div class="settings-section">
    <div class="empty-state">
      <span class="empty-ix">✎</span>
      <h3 class="empty-title">Bientôt disponible</h3>
      <p class="empty-text">L'édition du profil arrive dans une prochaine version</p>
      <%= link_to "← Retour au profil", profile_path, class: "btn-ghost" %>
    </div>
  </div>

</div>

<%= render "shared/bottom_nav", active: :me %>
