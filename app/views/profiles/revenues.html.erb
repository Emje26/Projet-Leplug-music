<div class="revenues-page">

  <!-- HEADER -->
  <header class="rev-header">
    <%= link_to profile_settings_path, class: "rev-back", "aria-label": "Retour aux paramètres" do %>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
    <% end %>
    <div class="rev-header-title">
      <h1>Revenus</h1>
      <span class="rev-header-sub">Revenus &amp; retraits</span>
    </div>
    <button class="rev-dots" aria-label="Menu">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><circle cx="12" cy="5" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="12" cy="19" r="1.5"/></svg>
    </button>
  </header>

  <!-- CARTE SOLDE -->
  <section class="rev-balance-card">
    <span class="rev-label label">Solde disponible</span>
    <div class="rev-amount">
      <span class="rev-amount-main">247</span><span class="rev-amount-cents">.80€</span>
    </div>
    <div class="rev-delta">
      <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#3DDC97" stroke-width="2"><path d="M18 15l-6-6-6 6"/></svg>
      <span class="rev-delta-pct">+34.2%</span>
      <span class="rev-delta-vs">vs mois dernier</span>
    </div>
    <a href="#" class="rev-withdraw-btn">
      Retirer
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </a>
    <span class="rev-withdraw-hint">Min. 50€ · Virement 2-3j</span>
  </section>

  <!-- SOURCES DE REVENUS -->
  <section class="rev-sources">
    <span class="rev-section-label">Sources de revenus</span>
    <div class="rev-sources-grid">
      <% [
        { label: "Écoutes", amount: "142.50€", pct: 58 },
        { label: "Plugs",   amount: "68.30€",  pct: 28 },
        { label: "Tips",    amount: "25.00€",  pct: 10 },
        { label: "Collabs", amount: "12.00€",  pct: 4  }
      ].each do |src| %>
        <div class="rev-source-card">
          <span class="rev-source-label"><%= src[:label] %></span>
          <span class="rev-source-amount"><%= src[:amount] %></span>
          <div class="rev-source-bar">
            <div class="rev-source-fill" style="--w: <%= src[:pct] %>%;"></div>
          </div>
          <span class="rev-source-pct"><%= src[:pct] %>%</span>
        </div>
      <% end %>
    </div>
  </section>

  <!-- ÉVOLUTION -->
  <section class="rev-evolution">
    <div class="rev-evo-header">
      <span class="rev-section-label">Évolution</span>
      <div class="rev-evo-tabs">
        <span class="rev-evo-tab">7j</span>
        <span class="rev-evo-tab active">30j</span>
        <span class="rev-evo-tab">90j</span>
      </div>
    </div>
    <div class="rev-chart">
      <svg viewBox="0 0 300 100" preserveAspectRatio="none" class="rev-chart-svg" aria-hidden="true">
        <defs>
          <linearGradient id="revLine" x1="0" y1="0" x2="1" y2="0">
            <stop offset="0%" stop-color="#2F6BFF"/>
            <stop offset="100%" stop-color="#57E1FF"/>
          </linearGradient>
          <linearGradient id="revFill" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="rgba(87,225,255,0.25)"/>
            <stop offset="100%" stop-color="rgba(47,107,255,0)"/>
          </linearGradient>
        </defs>
        <polygon fill="url(#revFill)"
          points="10,80 30,75 50,70 70,72 90,65 110,60 130,55 150,58 170,50 190,45 210,42 230,35 250,30 270,25 290,18 290,100 10,100"/>
        <polyline fill="none" stroke="url(#revLine)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
          points="10,80 30,75 50,70 70,72 90,65 110,60 130,55 150,58 170,50 190,45 210,42 230,35 250,30 270,25 290,18"/>
        <circle cx="290" cy="18" r="3" fill="#57E1FF"/>
      </svg>
      <div class="rev-chart-labels">
        <span>16 MAR</span><span>23 MAR</span><span>30 MAR</span><span>06 AVR</span><span>15 AVR</span>
      </div>
    </div>
  </section>

  <!-- DERNIÈRES TRANSACTIONS -->
  <section class="rev-transactions">
    <span class="rev-section-label">Dernières transactions</span>
    <% [
      { label: "Écoutes — Minuit à Barbès", date: "15 AVR", amount: "+8.40€", type: :income },
      { label: "Tip de @samira.k",          date: "14 AVR", amount: "+5.00€", type: :income },
      { label: "Plug bonus x3",             date: "13 AVR", amount: "+3.20€", type: :income },
      { label: "Retrait IBAN",              date: "12 AVR", amount: "-150€",  type: :expense },
      { label: "Écoutes — Béton ft. Marwa", date: "11 AVR", amount: "+6.80€", type: :income }
    ].each do |tx| %>
      <div class="rev-tx-row">
        <div class="rev-tx-icon <%= tx[:type] == :income ? 'income' : 'expense' %>">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14">
            <% if tx[:type] == :income %>
              <path d="M12 19V5"/><path d="M5 12l7-7 7 7"/>
            <% else %>
              <path d="M12 5v14"/><path d="M19 12l-7 7-7-7"/>
            <% end %>
          </svg>
        </div>
        <div class="rev-tx-info">
          <span class="rev-tx-label"><%= tx[:label] %></span>
          <span class="rev-tx-date"><%= tx[:date] %></span>
        </div>
        <span class="rev-tx-amount <%= tx[:type] == :income ? 'income' : 'expense' %>"><%= tx[:amount] %></span>
      </div>
    <% end %>
  </section>

</div>

<%= render "shared/bottom_nav", active: :me %>
