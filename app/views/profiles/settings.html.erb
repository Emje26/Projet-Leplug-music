<div class="settings-page">

  <!-- HEADER -->
  <header class="settings-header">
    <%= link_to profile_path, class: "back-btn" do %>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="16" height="16">
        <path d="M15 6l-6 6 6 6"/>
      </svg>
    <% end %>
    <div class="settings-title-wrap">
      <h1 class="settings-title">PARAMÈTRES</h1>
      <span class="settings-sub">ET ACTIVITÉ</span>
    </div>
    <span class="header-spacer"></span>
  </header>

  <!-- SEARCH -->
  <div class="settings-search">
    <div class="search-box">
      <span class="lbl">Q</span>
      <input type="text" placeholder="RECHERCHER">
    </div>
  </div>

  <!-- VOTRE COMPTE -->
  <section class="settings-section">
    <h2 class="section-label">VOTRE COMPTE</h2>

    <a class="settings-card" href="#">
      <span class="card-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
          <circle cx="12" cy="8" r="4"/>
          <path d="M4 21a8 8 0 0 1 16 0"/>
        </svg>
      </span>
      <div class="card-body">
        <span class="card-title">Espace Comptes</span>
        <span class="card-sub">Mot de passe, sécurité, informations personnelles</span>
      </div>
      <span class="card-arrow">›</span>
    </a>
  </section>

  <!-- ARGENT -->
  <section class="settings-section">
    <h2 class="section-label">ARGENT</h2>

    <a class="settings-card" href="#">
      <span class="card-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
          <line x1="12" y1="2"  x2="12" y2="22"/>
          <path d="M17 6H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
        </svg>
      </span>
      <div class="card-body">
        <span class="card-title">"Revenus"</span>
        <span class="card-sub">Gains, retraits, historique</span>
      </div>
      <span class="card-amount">€247.80</span>
      <span class="card-arrow">›</span>
    </a>

    <a class="settings-card" href="#">
      <span class="card-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
          <rect x="2" y="6" width="20" height="14" rx="1"/>
          <line x1="2" y1="11" x2="22" y2="11"/>
        </svg>
      </span>
      <div class="card-body">
        <span class="card-title">Moyen de paiement</span>
        <span class="card-sub">IBAN, carte, retrait</span>
      </div>
      <span class="card-arrow">›</span>
    </a>
  </section>

  <!-- COLLABORATIONS -->
  <section class="settings-section">
    <h2 class="section-label">COLLABORATIONS</h2>

    <a class="settings-card" href="#">
      <span class="card-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
          <circle cx="9"  cy="8" r="3"/>
          <circle cx="17" cy="9" r="2.5"/>
          <path d="M3 21a6 6 0 0 1 12 0"/>
          <path d="M14 21a5 5 0 0 1 7 0"/>
        </svg>
      </span>
      <div class="card-body">
        <span class="card-title">Mes collabs</span>
        <span class="card-sub">Feats, splits, contrats</span>
      </div>
      <span class="card-badge">3</span>
      <span class="card-arrow">›</span>
    </a>

    <a class="settings-card" href="#">
      <span class="card-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
          <polyline points="14 2 14 8 20 8"/>
          <line x1="8"  y1="13" x2="16" y2="13"/>
          <line x1="8"  y1="17" x2="14" y2="17"/>
        </svg>
      </span>
      <div class="card-body">
        <span class="card-title">Historique paiements</span>
        <span class="card-sub">Factures, reçus</span>
      </div>
      <span class="card-arrow">›</span>
    </a>
  </section>

  <!-- PRÉFÉRENCES -->
  <section class="settings-section">
    <h2 class="section-label">PRÉFÉRENCES</h2>

    <a class="settings-card" href="#">
      <span class="card-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
          <path d="M18 16v-5a6 6 0 1 0-12 0v5l-2 2h16l-2-2z"/>
          <path d="M10 20a2 2 0 0 0 4 0"/>
        </svg>
      </span>
      <div class="card-body">
        <span class="card-title">Notifications</span>
        <span class="card-sub">Push, email, DMs, plugs</span>
      </div>
      <span class="card-arrow">›</span>
    </a>

    <a class="settings-card" href="#">
      <span class="card-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
          <circle cx="12" cy="12" r="3"/>
          <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 1 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.6 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 1 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.6a1.65 1.65 0 0 0 1-1.51V3a2 2 0 1 1 4 0v.09A1.65 1.65 0 0 0 15 4.6a1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9c.36.15.69.37.95.64"/>
        </svg>
      </span>
      <div class="card-body">
        <span class="card-title">Général</span>
        <span class="card-sub">Langue, thème, lecture auto</span>
      </div>
      <span class="card-arrow">›</span>
    </a>

    <a class="settings-card" href="#">
      <span class="card-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
          <circle cx="12" cy="12" r="10"/>
          <line x1="12" y1="8"  x2="12" y2="12"/>
          <circle cx="12" cy="16" r="0.6" fill="currentColor"/>
        </svg>
      </span>
      <div class="card-body">
        <span class="card-title">Confidentialité</span>
        <span class="card-sub">Qui peut te "plug", DMs, blocages</span>
      </div>
      <span class="card-arrow">›</span>
    </a>
  </section>

  <!-- SESSION -->
  <section class="settings-section">
    <h2 class="section-label">SESSION</h2>

    <%= link_to destroy_user_session_path,
                data: { turbo_method: :delete },
                class: "settings-card danger" do %>
      <span class="card-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
          <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
          <polyline points="16 17 21 12 16 7"/>
          <line x1="21" y1="12" x2="9" y2="12"/>
        </svg>
      </span>
      <div class="card-body">
        <span class="card-title">Déconnexion</span>
        <span class="card-sub">Fermer la session en cours</span>
      </div>
      <span class="card-arrow">›</span>
    <% end %>
  </section>

</div>

<!-- BOTTOM NAV -->
<nav class="bottom-nav">
  <%= link_to root_path, class: "nav-item" do %>
    <svg viewBox="0 0 24 24"><path d="M3 10.5L12 3l9 7.5V21H3V10.5z"/></svg>
    <span>FEED</span>
  <% end %>
  <a class="nav-item" href="#">
    <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.5" y2="16.5"/></svg>
    <span>SEARCH</span>
  </a>
  <div class="nav-item nav-drop"><button class="drop-btn">+</button></div>
  <%= link_to chats_path, class: "nav-item" do %>
    <svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
    <span>DMS</span>
  <% end %>
  <%= link_to profile_path, class: "nav-item active" do %>
    <svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"/><path d="M4 21a8 8 0 0 1 16 0"/></svg>
    <span>ME</span>
  <% end %>
</nav>
