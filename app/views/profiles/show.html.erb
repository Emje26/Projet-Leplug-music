<div class="container py-4">
  <div class="row justify-content-center">
    <div class="col-md-8">
      <h2 class="mb-4">Your Profile</h2>

      <div class="card bg-dark text-white">
        <div class="card-body">
          <% if @profile.name.present? %>
            <h4><%= @profile.name %></h4>
          <% else %>
            <p class="text-muted">No name set yet.</p>
          <% end %>

          <% if @profile.bio.present? %>
            <p class="mt-3"><%= @profile.bio %></p>
          <% else %>
            <p class="text-muted">No bio yet.</p>
          <% end %>

          <hr class="my-4">

          <%= link_to "Edit Profile", edit_profile_path, class: "btn btn-outline-primary" %>
        </div>
      </div>
    </div>
  </div>
</div>
