<%
  username  = current_user.email.split('@').first
  name      = @profile&.name.presence || username
  bio       = @profile&.bio.presence   || "Producteur / MC \u00b7 bas\u00e9 \u00e0 Paris 18e. En studio sur le prochain projet. \"Minuit \u00e0 Barb\u00e8s\" EP dispo."
  handle    = "@#{username}"
  tracks = [
    { title: "MINUIT \u00c0 BARB\u00c8S",  time: "03:24", plays: "2.1K" },
    { title: "B\u00c9TON FT. MARWA",  time: "02:58", plays: "1.8K" },
    { title: "FANT\u00d4ME",          time: "04:12", plays: "956"  },
    { title: "18E ARRONDISSEMENT", time: "03:47", plays: "742" }
  ]
%>

<div class="profile-page">

  <!-- HERO -->
  <div class="profile-hero">
    <div class="profile-clouds-wrap">
      <%= render "shared/clouds" %>
    </div>

    <header class="profile-header">
      <%= link_to root_path, class: "hdr-back" do %>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M15 6l-6 6 6 6"/></svg>
      <% end %>
      <div class="hdr-handle"><%= handle %></div>
      <div class="hdr-actions">
        <button class="hdr-action" aria-label="Share">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
            <path d="M4 12v8a1 1 0 0 0 1 1h14a1 1 0 0 0 1-1v-8"/>
            <path d="M16 6l-4-4-4 4"/>
            <line x1="12" y1="2" x2="12" y2="15"/>
          </svg>
        </button>
        <%= link_to profile_settings_path, class: "hdr-action", "aria-label": "Settings" do %>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
            <circle cx="12" cy="12" r="1.5"/>
            <circle cx="5"  cy="12" r="1.5"/>
            <circle cx="19" cy="12" r="1.5"/>
          </svg>
        <% end %>
      </div>
    </header>

    <!-- AVATAR + NAME -->
    <section class="profile-identity">
      <div class="pi-avatar">
        <span class="av-badge"></span>
      </div>
      <div class="pi-meta">
        <h1 class="pi-name"><%= name.upcase %></h1>
        <span class="pi-specialty">PRODUCTEUR / MC</span>
        <span class="pi-city">PARIS 18E</span>
      </div>
    </section>
  </div>

  <!-- STATS -->
  <section class="profile-stats">
    <div class="stat-cell">
      <span class="stat-label q">PLUGS</span>
      <div class="stat-number">847</div>
    </div>
    <div class="stat-cell">
      <span class="stat-label q">\u00c9COUTES</span>
      <div class="stat-number">12.4K</div>
    </div>
    <div class="stat-cell">
      <span class="stat-label q">TRACKS</span>
      <div class="stat-number"><%= tracks.size %></div>
    </div>
  </section>

  <!-- ACTIONS -->
  <section class="profile-actions">
    <%= link_to "PLUG", "#", class: "btn-signal" %>
    <%= link_to "MESSAGE", chats_path, class: "btn-ghost" %>
  </section>

  <!-- DRIP -->
  <div class="profile-drip-wrap">
    <%= render "shared/drip" %>
  </div>

  <!-- TABS -->
  <nav class="profile-tabs">
    <button class="tab active">SONS</button>
    <button class="tab">CLIPS</button>
    <button class="tab">BIO</button>
  </nav>

  <!-- TRACKS -->
  <section class="profile-tracks">
    <% tracks.each_with_index do |t, i| %>
      <div class="track-row <%= 'playing' if i == 0 %>">
        <button class="tr-play"><%= i == 0 ? "\u275A\u275A" : "\u25B6" %></button>
        <div class="tr-meta">
          <h3 class="tr-name"><%= t[:title] %></h3>
          <div class="tr-sub"><%= t[:plays] %> plays</div>
        </div>
        <span class="tr-duration"><%= t[:time] %></span>
        <% if i == 0 %>
          <div class="tr-eq-wrap">
            <%= render "shared/equalizer" %>
          </div>
        <% end %>
      </div>
    <% end %>
  </section>

</div>

<%= render "shared/bottom_nav", active: :me %>
