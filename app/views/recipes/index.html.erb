<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Kitchen Guru - Your Recipes</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,400&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    /* ============================================
       KITCHENGURU - RECIPES INDEX PAGE
       Warm Mocha Brown Theme
       ============================================ */

    :root {
      /* Mocha Brown Palette - Deliberately darker to remain mocha on brightened screens */
      --mocha-darkest: #2c1810;
      --mocha-dark: #3d251a;
      --mocha-medium: #4a2c1c;
      --mocha-base: #5c3a2e;
      --mocha-light: #7a5244;
      --mocha-lighter: #9b7566;

      /* Background Colors */
      --bg-primary: #f8f4f1;
      --bg-secondary: #f0e9e4;
      --bg-tertiary: #e8dfd8;
      --bg-card: #ffffff;

      /* Accent Colors */
      --accent-primary: #c4704a;
      --accent-secondary: #d4a574;
      --accent-tertiary: #8b5a3c;
      --accent-danger: #b85450;

      /* Shadows */
      --shadow-sm: 0 2px 8px rgba(44, 24, 16, 0.08);
      --shadow-card: 0 4px 20px rgba(44, 24, 16, 0.06);
      --shadow-card-hover: 0 12px 40px rgba(44, 24, 16, 0.12);

      /* Border */
      --border-color: rgba(92, 58, 46, 0.12);
    }

    * {
      box-sizing: border-box;
    }

    body {
      font-family: 'Plus Jakarta Sans', -apple-system, sans-serif;
      background: var(--bg-primary);
      color: var(--mocha-darkest);
      line-height: 1.6;
      margin: 0;
      min-height: 100vh;
    }

    /* Subtle background texture */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background:
        radial-gradient(ellipse 80% 50% at 20% 20%, rgba(196, 112, 74, 0.03) 0%, transparent 50%),
        radial-gradient(ellipse 60% 40% at 80% 80%, rgba(212, 165, 116, 0.04) 0%, transparent 50%);
      pointer-events: none;
      z-index: -1;
    }

    /* ============================================
       NAVBAR
       ============================================ */

    header.border-bottom {
      background: var(--bg-card) !important;
      border-bottom-color: var(--border-color) !important;
      box-shadow: var(--shadow-sm);
    }

    .navbar {
      padding: 1rem 0;
    }

    .navbar-brand {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      text-decoration: none;
    }

    .navbar-brand img {
      height: 36px;
      width: auto;
    }

    .navbar-brand span {
      font-family: 'Fraunces', Georgia, serif;
      font-size: 1.25rem;
      font-weight: 600;
      color: var(--mocha-dark);
      letter-spacing: -0.01em;
    }

    .navbar-nav {
      align-items: center;
    }

    .navbar-nav .nav-link {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 0.9rem;
      font-weight: 500;
      color: var(--mocha-base);
      padding: 0.5rem 1rem;
      border-radius: 8px;
      transition: all 0.25s ease;
      text-decoration: none;
    }

    .navbar-nav .nav-link:hover {
      color: var(--mocha-dark);
      background: var(--bg-secondary);
    }

    .navbar-nav .nav-link.active {
      color: var(--accent-primary);
      background: rgba(196, 112, 74, 0.08);
    }

    .user-avatar {
      width: 38px;
      height: 38px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(135deg, var(--mocha-base), var(--mocha-light));
      color: white;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 0.85rem;
      font-weight: 600;
      border-radius: 50%;
      cursor: pointer;
      transition: all 0.25s ease;
    }

    .user-avatar:hover {
      transform: scale(1.05);
      box-shadow: 0 4px 12px rgba(92, 58, 46, 0.25);
    }

    /* ============================================
       MAIN CONTENT
       ============================================ */

    #main-content {
      min-height: calc(100vh - 80px);
      animation: fadeIn 0.6s ease-out;
    }

    @keyframes fadeIn {
      from { opacity: 0; }
      to { opacity: 1; }
    }

    @keyframes fadeInUp {
      from {
        opacity: 0;
        transform: translateY(20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    /* ============================================
       PAGE TITLE
       ============================================ */

    .page-title {
      font-family: 'Fraunces', Georgia, serif;
      font-size: 2.25rem;
      font-weight: 600;
      color: var(--mocha-darkest);
      letter-spacing: -0.02em;
      margin-bottom: 0.5rem;
      animation: fadeInUp 0.5s ease-out;
    }

    .page-subtitle {
      font-size: 1rem;
      color: var(--mocha-light);
      animation: fadeInUp 0.5s ease-out 0.1s both;
    }

    /* ============================================
       BUTTONS
       ============================================ */

    .btn {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-weight: 600;
      letter-spacing: 0.01em;
      transition: all 0.25s ease;
      border-radius: 50px;
    }

    .btn-primary {
      background: linear-gradient(135deg, var(--accent-primary), #a85f3d);
      border: none;
      color: white;
      padding: 0.5rem 1.5rem;
      font-size: 0.9rem;
    }

    .btn-primary:hover:not(:disabled) {
      background: linear-gradient(135deg, #a85f3d, #8f5035);
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(196, 112, 74, 0.35);
    }

    .btn-primary:disabled {
      background: var(--mocha-lighter);
      opacity: 0.6;
      cursor: not-allowed;
    }

    .btn-outline-primary {
      color: var(--accent-primary);
      border: 1.5px solid var(--accent-primary);
      background: transparent;
    }

    .btn-outline-primary:hover {
      background: var(--accent-primary);
      border-color: var(--accent-primary);
      color: white;
      transform: translateY(-2px);
    }

    .btn-outline-danger {
      color: var(--accent-danger);
      border: 1.5px solid rgba(184, 84, 80, 0.4);
      background: transparent;
    }

    .btn-outline-danger:hover {
      background: var(--accent-danger);
      border-color: var(--accent-danger);
      color: white;
    }

    .btn-sm {
      padding: 0.25rem 1rem;
      font-size: 0.8rem;
    }

    /* ============================================
       RECIPE CARDS
       ============================================ */

    .card {
      background: var(--bg-card);
      border-radius: 20px;
      box-shadow: var(--shadow-card);
      border: 1px solid var(--border-color);
      transition: all 0.25s ease;
      overflow: hidden;
    }

    .card:hover {
      transform: translateY(-4px);
      box-shadow: var(--shadow-card-hover);
      border-color: rgba(196, 112, 74, 0.3);
    }

    /* Staggered animation for cards */
    .col-md-4:nth-child(1) .card { animation: fadeInUp 0.5s ease-out 0.1s both; }
    .col-md-4:nth-child(2) .card { animation: fadeInUp 0.5s ease-out 0.18s both; }
    .col-md-4:nth-child(3) .card { animation: fadeInUp 0.5s ease-out 0.26s both; }
    .col-md-4:nth-child(4) .card { animation: fadeInUp 0.5s ease-out 0.34s both; }
    .col-md-4:nth-child(5) .card { animation: fadeInUp 0.5s ease-out 0.42s both; }
    .col-md-4:nth-child(6) .card { animation: fadeInUp 0.5s ease-out 0.5s both; }

    .card-body {
      padding: 1.5rem;
    }

    .card-body h5 {
      font-family: 'Fraunces', Georgia, serif;
      font-size: 1.1rem;
      font-weight: 600;
      color: var(--mocha-darkest);
      line-height: 1.4;
      margin-bottom: 0.5rem;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .card-body .text-muted {
      font-size: 0.85rem;
      color: var(--mocha-light) !important;
      line-height: 1.5;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .card-body .text-secondary {
      color: var(--mocha-lighter) !important;
      font-size: 0.8rem;
    }

    .card-body .text-secondary .fw-semibold {
      color: var(--mocha-base);
    }

    /* Card action buttons container */
    .card .mt-auto {
      padding-top: 1rem;
      border-top: 1px solid var(--border-color);
      margin-top: 1rem;
    }

    /* ============================================
       RESPONSIVE
       ============================================ */

    @media (max-width: 768px) {
      .page-title {
        font-size: 1.75rem;
      }

      .card-body {
        padding: 1rem;
      }

      .card-body h5 {
        font-size: 1rem;
      }
    }

    @media (max-width: 576px) {
      .navbar-brand span {
        font-size: 1.1rem;
      }

      .navbar-nav .nav-link {
        padding: 0.25rem 0.5rem;
        font-size: 0.85rem;
      }
    }

    /* ============================================
       REDUCED MOTION
       ============================================ */

    @media (prefers-reduced-motion: reduce) {
      *,
      *::before,
      *::after {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
      }
    }
  </style>
</head>
