<div class="container py-4">
  <div class="row justify-content-center">
    <div class="col-md-8">
      <h2 class="mb-4">Create a New Recipe</h2>

      <div class="card bg-dark text-white">
        <div class="card-body">
          <p class="text-muted mb-3">
            Describe the recipe you want and KitchenGuru AI will generate it for you.
          </p>

          <%= form_with url: recipes_path, method: :post, local: true do |f| %>
            <div class="mb-3">
              <%= f.label :prompt, "What do you want to cook?", class: "form-label" %>
              <%= f.text_area :prompt,
                              class: "form-control bg-secondary text-white",
                              rows: 4,
                              placeholder: "E.g., A healthy Mediterranean salad with chickpeas and feta cheese..." %>
            </div>

            <div class="d-flex gap-2">
              <%= f.submit "Generate Recipe", class: "btn btn-success" %>
              <%= link_to "Cancel", recipes_path, class: "btn btn-outline-secondary" %>
            </div>
          <% end %>
        </div>
      </div>

      <div class="mt-4">
        <p class="text-muted small">
          💡 <strong>Tip:</strong> Be specific about ingredients, dietary preferences,
          and cooking style for better results.
        </p>
      </div>
    </div>
  </div>
</div>
