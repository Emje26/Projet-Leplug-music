<%
  username = current_user.email.split('@').first
%>

<div class="search-page">

  <!-- ============ TOPBAR ============ -->
  <header class="search-topbar">
    <div>
      <div class="s-brand">LE PLUG</div>
      <span class="s-brand-sub">"SEARCH" / MARKETPLACE</span>
    </div>
    <div class="s-topbar-actions">
      <%= link_to bookings_path, class: "icon-btn", "aria-label": "Mes bookings" do %>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
          <rect x="3" y="4" width="18" height="18" rx="0"/>
          <line x1="16" y1="2"  x2="16" y2="6"/>
          <line x1="8"  y1="2"  x2="8"  y2="6"/>
          <line x1="3"  y1="10" x2="21" y2="10"/>
        </svg>
      <% end %>
      <button class="icon-btn" aria-label="Notifications">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
          <path d="M18 16v-5a6 6 0 1 0-12 0v5l-2 2h16l-2-2z"/>
          <path d="M10 20a2 2 0 0 0 4 0"/>
        </svg>
      </button>
    </div>
  </header>

  <!-- ============ HERO SEARCH ============ -->
  <section class="search-hero">
    <span class="s-catalog">№ 002 · MARKETPLACE</span>
    <h1 class="s-hero-title">
      TROUVE<br>
      TON <span class="slash">/STUDIO/</span>.
    </h1>
    <p class="s-hero-sub">Studios, beatmakers, mixeurs, clips, pochettes. Tout Paris, un seul "plug".</p>

    <%= form_with url: search_results_path, method: :get, class: "s-search-form", local: true do %>
      <div class="s-search-box">
        <span class="lbl">Q</span>
        <input type="text" name="q" placeholder="EX: STUDIO TRAP, MIXAGE, BEATMAKER…" autocomplete="off">
        <button type="submit" class="s-search-submit">→</button>
      </div>
    <% end %>
  </section>

  <!-- ============ FILTRES / PILLS ============ -->
  <div class="section-head">
    <h2 class="section-title">CATÉGORIES</h2>
  </div>

  <nav class="category-pills">
    <% @categories.each do |c| %>
      <%= link_to c[:label], search_results_path(category: c[:slug]), class: "category-pill" %>
    <% end %>
  </nav>

  <!-- ============ PRÈS DE TOI ============ -->
  <div class="section-head">
    <h2 class="section-title">PRÈS DE TOI</h2>
    <%= link_to "VOIR TOUT →", studios_path, class: "section-link" %>
  </div>

  <div class="studio-scroll">
    <% @nearby_studios.each do |s| %>
      <%= link_to studio_path(s), class: "studio-card" do %>
        <div class="sc-cover">
          <span class="sc-initials"><%= s.initials %></span>
          <span class="sc-category"><%= s.category&.upcase %></span>
        </div>
        <div class="sc-body">
          <h3 class="sc-name"><%= s.name.upcase %></h3>
          <div class="sc-meta">
            <span class="sc-city"><%= s.city %></span>
            <span class="sc-dot">·</span>
            <span class="sc-rating">★ <%= format("%.1f", s.rating) %></span>
          </div>
          <span class="sc-price"><%= s.display_price %></span>
        </div>
      <% end %>
    <% end %>
  </div>

  <!-- ============ TOP TALENTS ============ -->
  <div class="section-head">
    <h2 class="section-title">TOP TALENTS</h2>
    <%= link_to "VOIR TOUT →", talents_path, class: "section-link" %>
  </div>

  <div class="studio-scroll">
    <% @nearby_talents.each do |t| %>
      <%= link_to talent_path(t), class: "studio-card talent" do %>
        <div class="sc-cover">
          <span class="sc-initials"><%= t.initials %></span>
          <span class="sc-category"><%= t.specialty&.upcase %></span>
        </div>
        <div class="sc-body">
          <h3 class="sc-name"><%= t.name %></h3>
          <div class="sc-meta">
            <span class="sc-city"><%= t.city %></span>
            <span class="sc-dot">·</span>
            <span class="sc-rating">★ <%= format("%.1f", t.rating) %></span>
          </div>
          <span class="sc-price"><%= t.display_price %></span>
        </div>
      <% end %>
    <% end %>
  </div>

  <!-- ============ EXPLORER PAR MÉTIER ============ -->
  <div class="section-head">
    <h2 class="section-title">EXPLORER PAR MÉTIER</h2>
  </div>

  <div class="trades-grid">
    <% @trades.each_with_index do |trade, i| %>
      <%= link_to search_results_path(category: trade[:slug]), class: "trade-card" do %>
        <span class="tc-num">№ <%= format("%02d", i + 1) %></span>
        <h3 class="tc-label"><%= trade[:label] %></h3>
        <span class="tc-arrow">→</span>
      <% end %>
    <% end %>
  </div>

</div>

<%= render "shared/bottom_nav", active: :search %>
