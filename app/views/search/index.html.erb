<div class="search-page">

  <!-- ============ HEADER + DRIP ============ -->
  <header class="search-topbar">
    <span class="s-brand">LE PLUG</span>
    <div class="s-topbar-actions">
      <%= link_to bookings_path, class: "icon-btn", "aria-label": "Mes bookings" do %>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
          <rect x="3" y="4" width="18" height="18" rx="2"/>
          <line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/>
          <line x1="3" y1="10" x2="21" y2="10"/>
        </svg>
      <% end %>
      <button class="icon-btn" aria-label="Notifications">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
          <path d="M18 16v-5a6 6 0 1 0-12 0v5l-2 2h16l-2-2z"/>
          <path d="M10 20a2 2 0 0 0 4 0"/>
        </svg>
      </button>
    </div>
  </header>
  <%= render "shared/drip" %>

  <!-- ============ SEARCH BAR ============ -->
  <section class="search-hero">
    <%= form_with url: search_results_path, method: :get, class: "s-search-form", local: true do %>
      <div class="s-search-box">
        <svg class="s-search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
          <circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.5" y2="16.5"/>
        </svg>
        <input type="text" name="q" placeholder="Studios, beatmakers, mixage…" autocomplete="off">
      </div>
    <% end %>
  </section>

  <!-- ============ FILTRES / PILLS ============ -->
  <nav class="category-pills">
    <span class="category-pill active">"TOUT"</span>
    <% @categories.each do |c| %>
      <%= link_to search_results_path(category: c[:slug]), class: "category-pill" do %>
        "<%= c[:label] %>"
      <% end %>
    <% end %>
  </nav>

  <!-- ============ FEATURED ============ -->
  <% if @nearby_studios.any? %>
    <div class="section-head">
      <h2 class="section-title q">PRÈS DE TOI</h2>
      <%= link_to "VOIR TOUT →", studios_path, class: "section-link" %>
    </div>

    <div class="studio-scroll">
      <% @nearby_studios.each_with_index do |s, i| %>
        <%= link_to studio_path(s), class: "studio-card #{'featured' if i == 0}" do %>
          <div class="sc-cover">
            <span class="sc-initials"><%= s.initials %></span>
            <% if i == 0 %>
              <span class="sc-featured q">FEATURED</span>
              <div class="sc-starburst"><%= render "shared/starburst", size: :mini %></div>
            <% end %>
            <span class="sc-category q"><%= s.category&.upcase %></span>
          </div>
          <div class="sc-body">
            <h3 class="sc-name"><%= s.name %></h3>
            <div class="sc-meta"><%= s.city %> · ★ <%= format("%.1f", s.rating) %></div>
            <span class="sc-price"><%= s.display_price %></span>
          </div>
        <% end %>
      <% end %>
    </div>
  <% end %>

  <!-- ============ TOP TALENTS ============ -->
  <% if @nearby_talents.any? %>
    <div class="section-head">
      <h2 class="section-title q">TOP TALENTS</h2>
      <%= link_to "VOIR TOUT →", talents_path, class: "section-link" %>
    </div>

    <div class="studio-scroll">
      <% @nearby_talents.each do |t| %>
        <%= link_to talent_path(t), class: "studio-card talent" do %>
          <div class="sc-cover">
            <span class="sc-initials"><%= t.initials %></span>
            <div class="sc-starburst"><%= render "shared/starburst", size: :mini %></div>
            <span class="sc-category"><%= t.specialty&.upcase %></span>
          </div>
          <div class="sc-body">
            <h3 class="sc-name"><%= t.name %></h3>
            <div class="sc-meta"><%= t.city %> · ★ <%= format("%.1f", t.rating) %></div>
            <span class="sc-price"><%= t.display_price %></span>
          </div>
        <% end %>
      <% end %>
    </div>
  <% end %>

  <!-- ============ TENDANCES ============ -->
  <div class="section-head">
    <h2 class="section-title q">TENDANCES</h2>
  </div>

  <div class="trend-list">
    <% (@nearby_studios.first(5) + @nearby_talents.first(3)).each_with_index do |item, i| %>
      <%
        path  = item.is_a?(Studio) ? studio_path(item) : talent_path(item)
        label = item.is_a?(Studio) ? item.category&.upcase : item.specialty&.upcase
      %>
      <%= link_to path, class: "trend-row" do %>
        <span class="trend-rank"><%= format("%02d", i + 1) %></span>
        <div class="trend-cover"><span><%= item.initials %></span></div>
        <div>
          <h4 class="trend-name"><%= item.name %></h4>
          <div class="trend-sub"><%= label %> · <%= item.city %></div>
        </div>
        <span class="trend-delta">+<%= rand(80..400) %>%</span>
      <% end %>
    <% end %>
  </div>

  <!-- ============ EXPLORER PAR MÉTIER ============ -->
  <div class="section-head">
    <h2 class="section-title q">EXPLORER PAR MÉTIER</h2>
  </div>

  <div class="trades-grid">
    <% @trades.each_with_index do |trade, i| %>
      <%= link_to search_results_path(category: trade[:slug]), class: "trade-card" do %>
        <span class="tc-num">№ <%= format("%02d", i + 1) %></span>
        <h3 class="tc-label"><%= trade[:label] %></h3>
        <span class="tc-arrow">→</span>
      <% end %>
    <% end %>
  </div>

</div>

<%= render "shared/bottom_nav", active: :search %>
