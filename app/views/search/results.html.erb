<div class="search-page results">

  <!-- HEADER -->
  <header class="results-header">
    <%= link_to search_path, class: "back-btn", "aria-label": "Retour" do %>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="16" height="16">
        <path d="M15 6l-6 6 6 6"/>
      </svg>
    <% end %>
    <div class="results-title-wrap">
      <span class="results-kicker">Résultats</span>
      <h1 class="results-title">
        <%= @total %> résultat<%= "s" if @total != 1 %>
      </h1>
    </div>
    <span class="header-spacer"></span>
  </header>

  <!-- FILTRES ACTIFS -->
  <div class="results-filters">
    <%= form_with url: search_results_path, method: :get, class: "s-search-form compact", local: true do %>
      <div class="s-search-box">
        <svg class="s-search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
          <circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.5" y2="16.5"/>
        </svg>
        <input type="text" name="q" value="<%= @query %>" placeholder="Rechercher" autocomplete="off" aria-label="Rechercher">
        <% if @category.present? %>
          <input type="hidden" name="category" value="<%= @category %>">
        <% end %>
        <button type="submit" class="s-search-submit" aria-label="Lancer la recherche">→</button>
      </div>
    <% end %>

    <% if @query.present? || @category.present? || @city.present? %>
      <div class="active-chips">
        <% if @query.present?    %><span class="chip">Recherche : <%= @query %></span><% end %>
        <% if @category.present? %><span class="chip">Catégorie : <%= @category.capitalize %></span><% end %>
        <% if @city.present?     %><span class="chip">Ville : <%= @city.capitalize %></span><% end %>
        <%= link_to "Effacer ✕", search_results_path, class: "chip clear" %>
      </div>
    <% end %>
  </div>

  <!-- STUDIOS -->
  <% if @studios.any? %>
    <div class="section-head">
      <h2 class="section-title">Studios</h2>
      <span class="section-link"><%= @studios.size %></span>
    </div>

    <div class="results-list">
      <% @studios.each do |s| %>
        <%= link_to studio_path(s), class: "result-row" do %>
          <div class="rr-cover"><span><%= s.initials %></span></div>
          <div class="rr-body">
            <h3 class="rr-name"><%= s.name %></h3>
            <div class="rr-sub"><%= s.category&.capitalize %> · <%= s.city %> · ★ <%= format("%.1f", s.rating) %></div>
          </div>
          <span class="rr-price"><%= s.display_price %></span>
          <span class="rr-arrow">›</span>
        <% end %>
      <% end %>
    </div>
  <% end %>

  <!-- TALENTS -->
  <% if @talents.any? %>
    <div class="section-head">
      <h2 class="section-title">Talents</h2>
      <span class="section-link"><%= @talents.size %></span>
    </div>

    <div class="results-list">
      <% @talents.each do |t| %>
        <%= link_to talent_path(t), class: "result-row talent" do %>
          <div class="rr-cover"><span><%= t.initials %></span></div>
          <div class="rr-body">
            <h3 class="rr-name"><%= t.name %></h3>
            <div class="rr-sub"><%= t.specialty&.capitalize %> · <%= t.city %> · ★ <%= format("%.1f", t.rating) %></div>
          </div>
          <span class="rr-price"><%= t.display_price %></span>
          <span class="rr-arrow">›</span>
        <% end %>
      <% end %>
    </div>
  <% end %>

  <% if @studios.empty? && @talents.empty? %>
    <div class="empty-state" style="margin: 40px 20px;">
      <span class="empty-ix">0</span>
      <h3 class="empty-title">Aucun résultat</h3>
      <p class="empty-text">Essaie un autre terme ou une autre catégorie</p>
      <%= link_to "← Retour à l'exploration", search_path, class: "btn-ghost" %>
    </div>
  <% end %>

</div>

<%= render "shared/bottom_nav", active: :search %>
