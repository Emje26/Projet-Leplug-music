<% current = local_assigns[:active] %>

<nav class="bottom-nav" aria-label="Navigation principale">
  <%= link_to search_path, class: "nav-item #{'active' if current == :search}",
              "aria-current": (current == :search ? "page" : nil) do %>
    <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.5" y2="16.5"/></svg>
    <span>Explorer</span>
  <% end %>

  <%= link_to feed_path, class: "nav-item #{'active' if current == :feed}",
              "aria-current": (current == :feed ? "page" : nil) do %>
    <svg viewBox="0 0 24 24"><path d="M3 10.5L12 3l9 7.5V21H3V10.5z"/></svg>
    <span>Feed</span>
  <% end %>

  <div class="nav-item nav-drop">
    <%= link_to assistant_path, class: "drop-btn", "aria-label": "Créer avec PLUG/AI" do %>+<% end %>
  </div>

  <%= link_to chats_path, class: "nav-item #{'active' if current == :dms}",
              "aria-current": (current == :dms ? "page" : nil) do %>
    <svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
    <span>Messages</span>
  <% end %>

  <%= link_to profile_path, class: "nav-item #{'active' if current == :me}",
              "aria-current": (current == :me ? "page" : nil) do %>
    <svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"/><path d="M4 21a8 8 0 0 1 16 0"/></svg>
    <span>Profil</span>
  <% end %>
</nav>
