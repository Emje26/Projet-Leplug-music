<div class="search-page results">
  <header class="results-header">
    <%= link_to search_path, class: "back-btn" do %>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="16" height="16"><path d="M15 6l-6 6 6 6"/></svg>
    <% end %>
    <div class="results-title-wrap">
      <span class="results-kicker">"DIRECTORY"</span>
      <h1 class="results-title">TOUS LES TALENTS</h1>
    </div>
    <span class="header-spacer"></span>
  </header>

  <div class="results-list">
    <% @talents.each do |t| %>
      <%= link_to talent_path(t), class: "result-row talent" do %>
        <div class="rr-cover"><span><%= t.initials %></span></div>
        <div class="rr-body">
          <h3 class="rr-name"><%= t.name %></h3>
          <div class="rr-sub"><%= t.specialty&.upcase %> · <%= t.city %> · ★ <%= format("%.1f", t.rating) %></div>
        </div>
        <span class="rr-price"><%= t.display_price %></span>
        <span class="rr-arrow">›</span>
      <% end %>
    <% end %>
  </div>
</div>

<%= render "shared/bottom_nav", active: :search %>
